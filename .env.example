# ─────────────────────────────────────────────────────────────────
# Lead Dispatcher — Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────

# URL of your Cloud Run backend (REQUIRED for production)
# Get this after deploying the backend to Cloud Run.
# Example: https://cold-outreach-backend-xxxxx-uc.a.run.app
NEXT_PUBLIC_API_URL=https://your-backend-url.a.run.app

# Note: Do NOT prefix with NEXT_PUBLIC_ if the variable should stay server-side.
# NEXT_PUBLIC_ variables are exposed to the browser (which is what we want here
# since the browser needs to call the backend directly).
